{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "mdns": true
  },
  "provider": {
    "openicu": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenICU",
      "options": {
        "baseURL": "${OPENICU_BASE_URL}",
        "apiKey": "${OPENICU_API_KEY}"
      },
      "models": {
        "gpt-4o": { "name": "GPT-4o" },
        "gpt-4o-mini": { "name": "GPT-4o Mini" },
        "claude-sonnet-4-20250514": { "name": "Claude Sonnet 4" },
        "claude-haiku-4-20250514": { "name": "Claude Haiku 4" }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter",
      "options": {
        "baseURL": "${OPEN_ROUTER_API_BASE_URL}",
        "apiKey": "${OPEN_ROUTER_API_KEY}"
      },
      "models": {
        "deepseek/deepseek-chat-v3-0324": { "name": "DeepSeek V3" },
        "anthropic/claude-sonnet-4": { "name": "Claude Sonnet 4" },
        "openai/gpt-4o": { "name": "GPT-4o" }
      }
    },
    "openai": {
      "options": {
        "apiKey": "${OPEN_AI_API_KEY}"
      }
    },
    "anthropic": {
      "options": {
        "baseURL": "${ANTHROPIC_BASE_URL}",
        "apiKey": "${ANTHROPIC_AUTH_TOKEN}"
      }
    }
  },
  "model": "openicu/claude-sonnet-4-20250514",
  "small_model": "openicu/gpt-4o-mini",
  "mcp": {}
}
